# Docker Compose 环境变量示例（复制为项目根目录 .env）
# cp .env.docker.example .env

TZ=Asia/Shanghai

# MySQL
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=ai_passage_creator

# 端口
FRONTEND_PORT=80
BACKEND_PORT=8123

# 必需：AI 创作
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# 建议：Pexels 配图
PEXELS_API_KEY=

# Session / 密码盐（生产环境请修改）
SESSION_SECRET_KEY=change-me-in-production
PASSWORD_SALT=yupi

# 可选：Stripe VIP
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost/vip?success=true
STRIPE_CANCEL_URL=http://localhost/vip?cancelled=true

# 可选：AI 生图 / COS
NANO_BANANA_API_KEY=
NANO_BANANA_PROVIDER=gemini
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=

REDIS_PASSWORD=
