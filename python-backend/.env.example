# 服务器配置
SERVER_PORT=8567
SERVER_HOST=0.0.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_passage_creator
DB_USER=root
DB_PASSWORD=123456

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Session 配置
SESSION_SECRET_KEY=your-secret-key-change-in-production
SESSION_MAX_AGE=2592000

# 密码加密盐值
PASSWORD_SALT=yupi

# 可选：大模型（不配则 passage 占位；article 多智能体流程需配置 Key）
DASHSCOPE_API_KEY=
# 官方默认 qwen-plus；与 LLM_MODEL 二选一，未设 LLM_MODEL 时用此项
DASHSCOPE_MODEL=qwen-plus
# 兼容旧配置；未设置时走 DASHSCOPE_MODEL
LLM_MODEL=qwen-turbo

# 配图 / 存储（与官方一致，按需填写；空则仅部分配图方式可用）
PEXELS_API_KEY=
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=
TENCENT_COS_BUCKET=
TENCENT_COS_DOMAIN=
# AI 配图（NANO_BANANA）：二选一
# - 默认 gemini：填 NANO_BANANA_API_KEY（Google AI Studio）
# - 国内：NANO_BANANA_PROVIDER=dashscope，并配置上方 DASHSCOPE_API_KEY（通义万相 wanx，见百炼控制台）
NANO_BANANA_PROVIDER=gemini
# 与 NANO_BANANA_PROVIDER 等价；若前者被系统环境变量占用，可改用此项指定 dashscope / gemini
# AI_IMAGE_PROVIDER=dashscope
NANO_BANANA_API_KEY=
# NANO_BANANA_PROVIDER=dashscope 时使用，默认 wanx-v1
DASHSCOPE_WANX_MODEL=wanx-v1
DASHSCOPE_WANX_BASE_URL=https://dashscope.aliyuncs.com
# 万相易触发 429：创建任务重试次数、退避基数(秒)、两次万相调用之间最小间隔(秒)
DASHSCOPE_WANX_CREATE_MAX_RETRIES=8
DASHSCOPE_WANX_RETRY_BASE_SECONDS=2
DASHSCOPE_WANX_MIN_INTERVAL_SECONDS=0.55

# Mermaid：未安装本地 mmdc 时，默认用 Kroki 公网渲染（需能访问外网；内网/隐私环境可设为 false）
MERMAID_ENABLE_REMOTE_FALLBACK=true
MERMAID_REMOTE_KROKI_URL=https://kroki.io

# 智能体 LLM 失败自动重试（JSON 解析失败、限流等）
AGENT_LLM_MAX_RETRIES=3
AGENT_LLM_RETRY_BASE_SECONDS=1.5

# Reviewer：正文生成后审核（false 则跳过，与扩展前行为一致）
AGENT_REVIEWER_ENABLED=true
AGENT_REVIEWER_PASS_SCORE=75

# Stripe 支付（可选）
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/vip?success=true
STRIPE_CANCEL_URL=http://localhost:5173/vip?cancelled=true
